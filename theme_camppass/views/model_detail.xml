<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         MODEL DETAIL PAGE — WS1 (static example page)
         ============================================================ -->
    <template id="camppass_model_detail" name="Camppass Model Detail Page">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'model_detail'"/>
            <t t-set="title">WS1 — Camppass Premium Karavan</t>
            <t t-set="head">
                <meta name="description" content="Camppass WS1 model detayları. 800W güneş paneli, 245L su kapasitesi, bağımsız şasi."/>
            </t>
            <div id="wrap" class="oe_structure caravan-page">

                <t t-call="theme_camppass.camppass_header"/>

                <!-- Detail Hero -->
                <section class="cv-detail-hero">
                    <img src="/theme_camppass/static/src/img/model-cr555.webp" alt="WS1 Detail" loading="lazy"/>
                    <div class="cv-detail-hero-overlay"></div>
                    <div class="cv-detail-hero-content cv-container">
                        <div class="cv-breadcrumb-nav" style="margin-bottom:24px;">
                            <a href="/">Anasayfa</a>
                            <span class="separator">›</span>
                            <a href="/models">Modeller</a>
                            <span class="separator">›</span>
                            <span>WS1</span>
                        </div>
                        <h1 class="cv-animate">WS1</h1>
                        <div class="cv-model-card-price cv-animate cv-animate-delay-1">₺1.250.000'den başlayan</div>
                        <div style="margin-top:24px;" class="cv-animate cv-animate-delay-2">
                            <a href="/contact" class="cv-btn cv-btn-gold cv-btn-lg">Configure</a>
                            <a href="/contact" class="cv-btn cv-btn-outline cv-btn-lg" style="margin-left:12px;">Kirala</a>
                        </div>
                    </div>
                </section>

                <!-- Specs Grid -->
                <section class="cv-section">
                    <div class="cv-container">
                        <div class="cv-animate" style="text-align:center;">
                            <hr class="cv-gold-line centered"/>
                            <h2 class="cv-section-title">Teknik <span class="cv-accent-text">Özellikler</span></h2>
                        </div>

                        <div class="cv-detail-specs-grid">
                            <div class="cv-detail-spec-card cv-animate">
                                <span class="spec-value">800W</span>
                                <span class="spec-label">Güneş Paneli</span>
                            </div>
                            <div class="cv-detail-spec-card cv-animate cv-animate-delay-1">
                                <span class="spec-value">245L</span>
                                <span class="spec-label">Su Kapasitesi</span>
                            </div>
                            <div class="cv-detail-spec-card cv-animate cv-animate-delay-2">
                                <span class="spec-value">280mm</span>
                                <span class="spec-label">Süspansiyon</span>
                            </div>
                            <div class="cv-detail-spec-card cv-animate cv-animate-delay-3">
                                <span class="spec-value">35°</span>
                                <span class="spec-label">Maks. Eğim</span>
                            </div>
                            <div class="cv-detail-spec-card cv-animate cv-animate-delay-4">
                                <span class="spec-value">4.8m</span>
                                <span class="spec-label">Uzunluk</span>
                            </div>
                            <div class="cv-detail-spec-card cv-animate cv-animate-delay-5">
                                <span class="spec-value">2.2m</span>
                                <span class="spec-label">Genişlik</span>
                            </div>
                            <div class="cv-detail-spec-card cv-animate cv-animate-delay-6">
                                <span class="spec-value">1850kg</span>
                                <span class="spec-label">Ağırlık</span>
                            </div>
                            <div class="cv-detail-spec-card cv-animate">
                                <span class="spec-value">4 Kişi</span>
                                <span class="spec-label">Kapasite</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- 3D Viewer Placeholder -->
                <section class="cv-section cv-highlight-section">
                    <div class="cv-container">
                        <div class="cv-3d-viewer cv-animate">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                <path d="M2 17l10 5 10-5"/>
                                <path d="M2 12l10 5 10-5"/>
                            </svg>
                            <span>3D Model Görüntüleyici</span>
                            <span style="font-size:0.85rem;">Camppass karavanınızı 360° inceleyin</span>
                        </div>
                    </div>
                </section>

                <!-- Features -->
                <section class="cv-section">
                    <div class="cv-container">
                        <div class="cv-animate" style="text-align:center;">
                            <hr class="cv-gold-line centered"/>
                            <h2 class="cv-section-title">Öne Çıkan <span class="cv-accent-text">Özellikler</span></h2>
                        </div>

                        <div class="cv-detail-features">
                            <div class="cv-detail-feature-item cv-animate">
                                <div class="cv-detail-feature-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                                </div>
                                <div>
                                    <h4>Bağımsız Şasi Sistemi</h4>
                                    <p>Arazi koşullarına özel tasarlanmış bağımsız süspansiyon ve dayanıklı şasi yapısı.</p>
                                </div>
                            </div>
                            <div class="cv-detail-feature-item cv-animate cv-animate-delay-1">
                                <div class="cv-detail-feature-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                                </div>
                                <div>
                                    <h4>Tam Off-Grid Enerji</h4>
                                    <p>800W güneş paneli ve lityum batarya ile tamamen bağımsız enerji sistemi.</p>
                                </div>
                            </div>
                            <div class="cv-detail-feature-item cv-animate cv-animate-delay-2">
                                <div class="cv-detail-feature-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                                </div>
                                <div>
                                    <h4>Isıtma &amp; Klima</h4>
                                    <p>Dört mevsim konfor sağlayan entegre ısıtma ve klima sistemi.</p>
                                </div>
                            </div>
                            <div class="cv-detail-feature-item cv-animate cv-animate-delay-3">
                                <div class="cv-detail-feature-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                                </div>
                                <div>
                                    <h4>Akıllı Kontrol Paneli</h4>
                                    <p>Dokunmatik ekran ve mobil uygulama ile tüm sistemleri kontrol edin.</p>
                                </div>
                            </div>
                            <div class="cv-detail-feature-item cv-animate cv-animate-delay-4">
                                <div class="cv-detail-feature-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                </div>
                                <div>
                                    <h4>Premium İç Mekan</h4>
                                    <p>El yapımı ahşap detaylar ve ergonomik yaşam alanı tasarımı.</p>
                                </div>
                            </div>
                            <div class="cv-detail-feature-item cv-animate cv-animate-delay-5">
                                <div class="cv-detail-feature-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                </div>
                                <div>
                                    <h4>GPS Takip Sistemi</h4>
                                    <p>Entegre GPS ve güvenlik sistemi ile Camppass karavanınız her zaman güvende.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Gallery -->
                <section class="cv-section cv-highlight-section">
                    <div class="cv-container">
                        <div class="cv-animate" style="text-align:center;">
                            <hr class="cv-gold-line centered"/>
                            <h2 class="cv-section-title">Galeri</h2>
                        </div>

                        <div class="cv-gallery">
                            <div class="cv-gallery-item cv-animate">
                                <img src="/theme_camppass/static/src/img/gallery-cr555-1.webp" alt="Galeri 1" loading="lazy"/>
                            </div>
                            <div class="cv-gallery-item cv-animate cv-animate-delay-1">
                                <img src="/theme_camppass/static/src/img/gallery-cr555-2.webp" alt="Galeri 2" loading="lazy"/>
                            </div>
                            <div class="cv-gallery-item cv-animate cv-animate-delay-2">
                                <img src="/theme_camppass/static/src/img/gallery-cr555-3.webp" alt="Galeri 3" loading="lazy"/>
                            </div>
                            <div class="cv-gallery-item cv-animate cv-animate-delay-3">
                                <img src="/theme_camppass/static/src/img/gallery-cr555-4.webp" alt="Galeri 4" loading="lazy"/>
                            </div>
                            <div class="cv-gallery-item cv-animate cv-animate-delay-4">
                                <img src="/theme_camppass/static/src/img/gallery-cr555-5.webp" alt="Galeri 5" loading="lazy"/>
                            </div>
                            <div class="cv-gallery-item cv-animate cv-animate-delay-5">
                                <img src="/theme_camppass/static/src/img/gallery-cr650-1.webp" alt="Galeri 6" loading="lazy"/>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- CTA -->
                <section class="cv-cta-banner">
                    <div class="cv-container cv-animate">
                        <h2>WS1 ile <span class="cv-accent-text">Özgürlüğe Adım Atın</span></h2>
                        <p>Hayalinizdeki Camppass karavanı konfigüre edin veya hemen kiralayın.</p>
                        <div class="cv-cta-buttons">
                            <a href="/contact" class="cv-btn cv-btn-gold cv-btn-lg">Configure</a>
                            <a href="/contact" class="cv-btn cv-btn-outline cv-btn-lg">Kirala</a>
                        </div>
                    </div>
                </section>

                <t t-call="theme_camppass.camppass_footer"/>
            </div>
        </t>
    </template>

    <record id="camppass_model_detail_page" model="website.page">
        <field name="name">Model Detay - WS1</field>
        <field name="url">/model/ws1</field>
        <field name="is_published">True</field>
        <field name="view_id" ref="camppass_model_detail"/>
        <field name="website_indexed">True</field>
    </record>

</odoo>
