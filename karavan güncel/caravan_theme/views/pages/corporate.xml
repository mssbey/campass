                                <div class="cp-pillar-stat"><span class="cp-stat-num">2.000+</span><span class="cp-stat-lbl">M&#x00FC;hendislik Saati</span></div>
                            </div>
                        </div>
                        <!-- Pillar 2: Freedom -->
                        <div class="cp-pillar" data-pillar="free">
                            <div class="cp-pillar-icon">
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            </div>
                            <h3>&#x00D6;zg&#x00FC;rl&#x00FC;k</h3>
                            <p class="cp-pillar-short">Tamamen ba&#x011F;&#x0131;ms&#x0131;z ya&#x015F;am</p>
